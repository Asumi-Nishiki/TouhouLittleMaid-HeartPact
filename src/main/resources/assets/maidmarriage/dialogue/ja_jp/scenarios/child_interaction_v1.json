{
  "id": "maidmarriage:child_interaction_v1",
  "theme": "maidmarriage:hug_default",
  "start": "idle",
  "animationLibrary": "maidmarriage:default",
  "portraits": {
    "maid": {
      "texture": "maidmarriage:textures/gui/emotion/soft_smile.png",
      "defaultExpression": "soft_smile",
      "expressions": {
        "soft_smile": "maidmarriage:textures/gui/emotion/soft_smile.png",
        "happy": "maidmarriage:textures/gui/emotion/soft_smile.png",
        "shy": "maidmarriage:textures/gui/emotion/hot_smile.png"
      }
    }
  },
  "nodes": {
    "idle": {
      "type": "choice",
      "prompt": {
        "speaker": "${child_entry_speaker}",
        "text": "${child_entry_text}",
        "portrait": "maid",
        "expression": "soft_smile",
        "emotion": "normal",
        "animation": "fade_in",
        "events": []
      },
      "choices": [
        {
          "id": "pet_head",
          "title": "頭をなでる",
          "description": "そっと頭をなでて、安心させてあげる。",
          "next": "pet_head_intro",
          "action": "maidmarriage:pet_head",
          "events": []
        },
        {
          "id": "lift",
          "title": "高い高いする",
          "description": "小さなメイドを抱き上げる。すでに抱き上げている時は、そっと地面に戻す。",
          "next": "lift_intro",
          "action": "maidmarriage:lift_child",
          "events": []
        },
        {
          "id": "carry_child",
          "title": "ママに抱っこしてもらう",
          "description": "ママに抱っこしてもらう。すでに抱っこ中なら、下ろせるか試す。",
          "next": "carry_intro",
          "action": "maidmarriage:carry_child",
          "events": []
        },
        {
          "id": "comfort",
          "title": "そばで話す",
          "description": "しゃがんで目線を合わせ、少しだけ一緒におしゃべりする。",
          "next": "comfort_intro",
          "events": []
        },
        {
          "id": "child_gift",
          "title": "プレゼントを渡す",
          "description": "小さな贈り物を選んで、喜んでくれるか見てみる。",
          "next": "idle",
          "action": "maidmarriage:open_gift_screen",
          "events": []
        }
      ],
      "lines": [],
      "branches": [],
      "events": []
    },
    "pet_head_intro": {
      "type": "sequence",
      "lines": [
        {
          "speaker": "",
          "text": "あなたの手のひらが、そっと彼女の髪に降りる。彼女は安心したように、きゅっと目を細めた。",
          "portrait": "maid",
          "expression": "happy",
          "emotion": "happy",
          "animation": "soft_bounce",
          "events": []
        },
        {
          "speaker": "${maid}",
          "text": "えへへ……もうちょっとだけ、なでてもいいよ？",
          "expression": "happy",
          "emotion": "happy",
          "events": []
        }
      ],
      "next": "idle",
      "choices": [],
      "branches": [],
      "events": []
    },
    "lift_intro": {
      "type": "sequence",
      "lines": [
        {
          "speaker": "",
          "text": "彼女は思わずあなたの袖をつかみ、それから嬉しそうに足をぱたぱた揺らした。",
          "portrait": "maid",
          "expression": "happy",
          "emotion": "happy",
          "animation": "slide_up",
          "events": []
        },
        {
          "speaker": "${maid}",
          "text": "わあ、高い！　すっごく遠くまで見えるよ！",
          "expression": "happy",
          "emotion": "happy",
          "events": []
        }
      ],
      "next": "idle",
      "choices": [],
      "branches": [],
      "events": []
    },
    "carry_intro": {
      "type": "sequence",
      "lines": [
        {
          "speaker": "",
          "text": "彼女のママがそっと近づいて、小さな体を大事そうに抱きしめた。",
          "portrait": "maid",
          "expression": "soft_smile",
          "emotion": "gentle",
          "animation": "fade_in",
          "events": []
        },
        {
          "speaker": "${maid}",
          "text": "ママに抱っこされると、からだ全部がぽかぽかするの。",
          "expression": "happy",
          "emotion": "happy",
          "events": []
        }
      ],
      "next": "idle",
      "choices": [],
      "branches": [],
      "events": []
    },
    "comfort_intro": {
      "type": "sequence",
      "lines": [
        {
          "speaker": "",
          "text": "あなたはしゃがんで、彼女と同じ高さで目を合わせる。彼女はまっすぐにあなたを見つめた。",
          "portrait": "maid",
          "expression": "soft_smile",
          "emotion": "gentle",
          "animation": "fade_in",
          "events": []
        },
        {
          "speaker": "${maid}",
          "text": "あなたがそばにいてくれるなら、今日はもう、こわくない気がする。",
          "expression": "shy",
          "emotion": "gentle",
          "events": []
        }
      ],
      "next": "idle",
      "choices": [],
      "branches": [],
      "events": []
    }
  }
}
