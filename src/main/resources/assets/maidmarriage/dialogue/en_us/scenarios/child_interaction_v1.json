{
  "id": "maidmarriage:child_interaction_v1",
  "theme": "maidmarriage:hug_default",
  "start": "idle",
  "animationLibrary": "maidmarriage:default",
  "portraits": {
    "maid": {
      "texture": "maidmarriage:textures/gui/emotion/soft_smile.png",
      "defaultExpression": "soft_smile",
      "expressions": {
        "soft_smile": "maidmarriage:textures/gui/emotion/soft_smile.png",
        "happy": "maidmarriage:textures/gui/emotion/soft_smile.png",
        "shy": "maidmarriage:textures/gui/emotion/hot_smile.png"
      }
    }
  },
  "nodes": {
    "idle": {
      "type": "choice",
      "prompt": {
        "speaker": "${child_entry_speaker}",
        "text": "${child_entry_text}",
        "portrait": "maid",
        "expression": "soft_smile",
        "emotion": "normal",
        "animation": "fade_in",
        "events": []
      },
      "choices": [
        {
          "id": "pet_head",
          "title": "Pat Her Head",
          "description": "Gently pat her head and help her settle down.",
          "next": "pet_head_intro",
          "action": "maidmarriage:pet_head",
          "events": []
        },
        {
          "id": "lift",
          "title": "Lift Her Up",
          "description": "Pick the little maid up high; if she is already up, set her back down.",
          "next": "lift_intro",
          "action": "maidmarriage:lift_child",
          "events": []
        },
        {
          "id": "carry_child",
          "title": "Let Mom Hold Her",
          "description": "Ask her mother to hold her close; if she is already being carried, try putting her down.",
          "next": "carry_intro",
          "action": "maidmarriage:carry_child",
          "events": []
        },
        {
          "id": "comfort",
          "title": "Talk with Her",
          "description": "Crouch down and keep her company for a little while.",
          "next": "comfort_intro",
          "events": []
        },
        {
          "id": "child_gift",
          "title": "Give Her a Gift",
          "description": "Pick out a small present and see whether she likes it.",
          "next": "idle",
          "action": "maidmarriage:open_gift_screen",
          "events": []
        }
      ],
      "lines": [],
      "branches": [],
      "events": []
    },
    "pet_head_intro": {
      "type": "sequence",
      "lines": [
        {
          "speaker": "",
          "text": "Your palm comes to rest softly on her hair, and she narrows her eyes as if the touch has made her feel safe.",
          "portrait": "maid",
          "expression": "happy",
          "emotion": "angry",
          "animation": "soft_bounce",
          "events": []
        },
        {
          "speaker": "${maid}",
          "text": "Hehe... you can pat me a little more, okay?",
          "expression": "happy",
          "emotion": "tired",
          "events": []
        }
      ],
      "next": "idle",
      "choices": [],
      "branches": [],
      "events": []
    },
    "lift_intro": {
      "type": "sequence",
      "lines": [
        {
          "speaker": "",
          "text": "She catches your sleeve without thinking, then happily swings her feet in the air.",
          "portrait": "maid",
          "expression": "happy",
          "emotion": "happy",
          "animation": "slide_up",
          "events": []
        },
        {
          "speaker": "${maid}",
          "text": "Whoa, so high! I can see so, so far from here!",
          "expression": "happy",
          "emotion": "happy",
          "events": []
        }
      ],
      "next": "idle",
      "choices": [],
      "branches": [],
      "events": []
    },
    "carry_intro": {
      "type": "sequence",
      "lines": [
        {
          "speaker": "",
          "text": "Her mother steps closer and gathers her carefully into a steady embrace.",
          "portrait": "maid",
          "expression": "soft_smile",
          "emotion": "gentle",
          "animation": "fade_in",
          "events": []
        },
        {
          "speaker": "${maid}",
          "text": "When Mom holds me, everything feels all warm and cozy.",
          "expression": "happy",
          "emotion": "happy",
          "events": []
        }
      ],
      "next": "idle",
      "choices": [],
      "branches": [],
      "events": []
    },
    "comfort_intro": {
      "type": "sequence",
      "lines": [
        {
          "speaker": "",
          "text": "You crouch down until your eyes are level with hers, and she looks back at you with serious attention.",
          "portrait": "maid",
          "expression": "soft_smile",
          "emotion": "serious",
          "animation": "fade_in",
          "events": []
        },
        {
          "speaker": "${maid}",
          "text": "When you're beside me, I feel like today won't be scary at all.",
          "expression": "shy",
          "emotion": "gentle",
          "events": []
        }
      ],
      "next": "idle",
      "choices": [],
      "branches": [],
      "events": []
    }
  }
}
